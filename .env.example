# Copy this to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/business_registry

# Optional: UK Companies House API key (Tier 3)
# Register free at: https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# Optional: France INPI API key (Tier 3)
INPI_API_KEY=

# Flask secret key — change this
FLASK_SECRET_KEY=change-me-in-production
